# Generate with: openssl rand -base64 32
SECRET_KEY=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Set to your Ubuntu machine's local IP + frontend port
# Find IP with: ip addr show | grep "inet " | grep -v 127
# Must match FRONTEND_PORT below
AUTH_URL=http://UBUNTU_IP:3000

# Host ports — change any of these if they conflict with other services on the machine
# The app always listens internally on 3000/8000/9001; only the host-side numbers change
FRONTEND_PORT=3000
BACKEND_PORT=8000
MINIO_CONSOLE_PORT=9001
